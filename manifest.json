{
  "manifest_version": 2,
  "name": "My First Firefox Extension",
  "version": "1.0.0",
  "description": "A simple starter extension for Firefox.",
  "permissions": ["activeTab", "storage"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "My First Firefox Extension",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["calculator.js", "content.js"]
    }
  ]
}
