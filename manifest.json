{
  "manifest_version": 2,
  "name": "Simple Calculator Extension",
  "version": "1.0.0",
  "description": "A lightweight calculator for Firefox: use the popup, or double-click any editable field on a site you've allowed to calculate inline.",
  "permissions": ["activeTab", "storage"],
  "optional_permissions": ["*://*/*"],
  "background": {
    "scripts": ["shared.js", "background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "My First Firefox Extension",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "popup/settings.html",
    "open_in_tab": true,
    "browser_style": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "simple-calculator@wesleyblake95.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
